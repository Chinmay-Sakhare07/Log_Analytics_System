# ============================================================
# .env.example — Copy to .env and fill in values
# NEVER commit .env to git (it's in .gitignore)
# ============================================================

# ─── API Security ────────────────────────────────────────────
# Rationale: Single shared API key for local dev; rotate per environment.
# In production, use a secrets manager (AWS Secrets Manager, Render secrets).
INGESTION_API_KEY=dev-secret-key-change-in-prod
QUERY_API_KEY=dev-secret-key-change-in-prod

# ─── Cassandra / ScyllaDB ────────────────────────────────────
# Local dev: use container name as host (Docker DNS resolves it)
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=log_analytics
# ScyllaDB Cloud: set these (leave blank for local Cassandra)
SCYLLA_USERNAME=
SCYLLA_PASSWORD=
SCYLLA_DATACENTER=

# ─── PostgreSQL ──────────────────────────────────────────────
# Local dev DSN (matches docker-compose.yml credentials)
POSTGRES_DSN=postgresql://loguser:logpass@postgres:5432/logdb
# For external Postgres (Render/Railway/Supabase), replace the DSN above
# POSTGRES_DSN=postgresql://user:pass@host:5432/dbname?sslmode=require

# ─── Log Shipper ─────────────────────────────────────────────
INGESTION_URL=http://localhost:8000
LOG_DIR=./logs                      # Directory the shipper watches
SHIPPER_BATCH_SIZE=100
SHIPPER_FLUSH_INTERVAL_SECS=1

# ─── Observability ───────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARN | ERROR
ENABLE_PROMETHEUS=true              # Expose /metrics endpoint